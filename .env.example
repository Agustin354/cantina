# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Reemplaza con tu propia URI si cambiás la base de datos
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/
MONGODB_DB=quiosco

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Cambia este valor en producción por una cadena larga y aleatoria
SECRET_KEY=cambia_esta_clave_en_produccion

# ─── Puertos ──────────────────────────────────────────────────────────────────
# ventas_service
PORT=5000

# produccion_service
# PORT=5001

# ─── Producción service: prefijo de ruta externa (detrás de NGINX) ────────────
# Dejar vacío si accedés directamente al puerto 5001
EXTERNAL_PREFIX=/produccion
